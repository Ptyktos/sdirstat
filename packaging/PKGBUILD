# Maintainer: Clay Townsend <clay@twn.systems>
pkgname=sdirstat
pkgver=0.1.0
pkgrel=1
pkgdesc="Parallel disk-usage analyzer with a treemap/sunburst web GUI (subsumes baobab/qdirstat)"
arch=('x86_64')
url="https://github.com/Ptyktos/sdirstat"
license=('MIT' 'Apache')
depends=('glibc')
optdepends=('glib2: gio trash for Move to Trash in the GUI'
            'xdg-utils: Open / Reveal in the GUI')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::$url/-/archive/v$pkgver/$pkgname-v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$pkgname-v$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo build --release --locked
}

package() {
  cd "$pkgname-v$pkgver"
  install -Dm755 target/release/sdirstat        "$pkgdir/usr/bin/sdirstat"
  install -Dm755 packaging/sdirstat-gui         "$pkgdir/usr/bin/sdirstat-gui"
  install -Dm644 packaging/sdirstat.desktop     "$pkgdir/usr/share/applications/sdirstat.desktop"
  install -Dm644 packaging/sdirstat.svg         "$pkgdir/usr/share/icons/hicolor/scalable/apps/sdirstat.svg"
  install -Dm644 README.md                      "$pkgdir/usr/share/doc/$pkgname/README.md"
}
